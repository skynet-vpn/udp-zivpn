#!/bin/bash

# ===== Color Definitions - FIXED =====
YELLOW='\033[1;33m'
RED='\033[0;31m'
LIGHT_BLUE='\033[1;36m'
BOLD_WHITE='\033[1;37m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
LIGHT_GREEN='\033[1;32m'
NC='\033[0m'

# ===== Configuration - FIXED =====
LICENSE_URL="https://raw.githubusercontent.com/skynet-vpn/regip/main/ip"
LICENSE_INFO_FILE="/etc/zivpn/.license_info"
CONFIG_DIR="/etc/zivpn"
TELEGRAM_CONF="${CONFIG_DIR}/telegram.conf"

# ===== Root Check - FIXED =====
if [ "$(id -u)" -ne 0 ]; then
  echo -e "${RED}This script must be run as root. Please use sudo or run as root user.${NC}" >&2
  exit 1
fi

function send_telegram_notification() {
  local message="$1"
  local keyboard="$2"
  
  if [ ! -f "$TELEGRAM_CONF" ]; then
    return 1
  fi
  
  source "$TELEGRAM_CONF"
  
  if [ -n "$TELEGRAM_BOT_TOKEN" ] && [ -n "$TELEGRAM_CHAT_ID" ]; then
    local api_url="https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage"
    
    if [ -n "$keyboard" ]; then
      curl -s -X POST "$api_url" \
        -d "chat_id=${TELEGRAM_CHAT_ID}" \
        --data-urlencode "text=${message}" \
        -d "reply_markup=${keyboard}" > /dev/null
    else
      curl -s -X POST "$api_url" \
        -d "chat_id=${TELEGRAM_CHAT_ID}" \
        --data-urlencode "text=${message}" \
        -d "parse_mode=Markdown" > /dev/null
    fi
  fi
}

function verify_license() {
  echo -e "${LIGHT_BLUE}Verifying installation license...${NC}"
  local SERVER_IP
  SERVER_IP=$(cat /etc/zivpn/ip.txt 2>/dev/null)
  
  if [ -z "$SERVER_IP" ]; then
    echo -e "${RED}Failed to retrieve server IP. Please check your internet connection.${NC}"
    exit 1
  fi
  
  local license_data
  license_data=$(curl -s "$LICENSE_URL")
  
  if [ $? -ne 0 ] || [ -z "$license_data" ]; then
    echo -e "${RED}Gagal terhubung ke server lisensi. Mohon periksa koneksi internet Anda.${NC}"
    exit 1
  fi
  
  local license_entry
  license_entry=$(echo "$license_data" | grep -w "$SERVER_IP")
  
  if [ -z "$license_entry" ]; then
    echo -e "${RED}Verifikasi Lisensi Gagal! IP Anda tidak terdaftar. IP: ${SERVER_IP}${NC}"
    exit 1
  fi
  
  local client_name
  local expiry_date_str
  client_name=$(echo "$license_entry" | awk '{print $1}')
  expiry_date_str=$(echo "$license_entry" | awk '{print $2}')
  
  local expiry_timestamp
  expiry_timestamp=$(date -d "$expiry_date_str" +%s 2>/dev/null)
  
  local current_timestamp
  current_timestamp=$(date +%s)
  
  if [ "$expiry_timestamp" -le "$current_timestamp" ]; then
    echo -e "${RED}Verifikasi Lisensi Gagal! Lisensi untuk IP ${SERVER_IP} telah kedaluwarsa. Tanggal Kedaluwarsa: ${expiry_date_str}${NC}"
    exit 1
  fi
  
  echo -e "${LIGHT_GREEN}Verifikasi Lisensi Berhasil! Client: ${client_name}, IP: ${SERVER_IP}${NC}"
  sleep 2
  
  mkdir -p "$CONFIG_DIR"
  echo "CLIENT_NAME=${client_name}" > "$LICENSE_INFO_FILE"
  echo "EXPIRY_DATE=${expiry_date_str}" >> "$LICENSE_INFO_FILE"
}

function update_expiry_from_license_url() {
  echo -e "${LIGHT_BLUE}Syncing expiry license...${NC}"
  local SERVER_IP
  SERVER_IP=$(cat /etc/zivpn/ip.txt 2>/dev/null)
  
  if [ -z "$SERVER_IP" ]; then
    echo -e "${RED}Gagal mendapatkan IP server${NC}"
    return 1
  fi
  
  local license_data
  license_data=$(curl -s "$LICENSE_URL")
  
  if [ $? -ne 0 ] || [ -z "$license_data" ]; then
    echo -e "${RED}Gagal mengambil data lisensi${NC}"
    return 1
  fi
  
  local license_entry
  license_entry=$(echo "$license_data" | grep -w "$SERVER_IP")
  
  if [ -z "$license_entry" ]; then
    echo -e "${RED}IP tidak terdaftar di lisensi${NC}"
    return 1
  fi
  
  local CLIENT_NAME NEW_EXP_FROM_SERVER
  CLIENT_NAME=$(echo "$license_entry" | awk '{print $1}')
  NEW_EXP_FROM_SERVER=$(echo "$license_entry" | awk '{print $2}')
  
  if ! date -d "$NEW_EXP_FROM_SERVER" >/dev/null 2>&1; then
    echo -e "${RED}Format tanggal EXP dari server tidak valid${NC}"
    return 1
  fi
  
  mkdir -p "$CONFIG_DIR"
  cat > "$LICENSE_INFO_FILE" <<EOF
CLIENT_NAME=${CLIENT_NAME}
EXPIRY_DATE=${NEW_EXP_FROM_SERVER}
EOF
  
  echo -e "${LIGHT_GREEN}Sinkronisasi lisensi berhasil!${NC}"
  echo -e "${CYAN}Client  : ${CLIENT_NAME}${NC}"
  echo -e "${CYAN}Expiry  : ${NEW_EXP_FROM_SERVER}${NC}"
}

function restart_zivpn() {
  systemctl restart zivpn.service --no-block
}

function _create_account_logic() {
  local password="$1"
  local days="$2"
  local db_file="/etc/zivpn/users.db"
  
  if [ -z "$password" ] || [ -z "$days" ]; then
    echo -e "${RED}Error: Password and days are required.${NC}"
    return 1
  fi
  
  if ! [[ "$days" =~ ^[0-9]+$ ]]; then
    echo -e "${RED}Error: Invalid number of days.${NC}"
    return 1
  fi
  
  if grep -q "^${password}:" "$db_file" 2>/dev/null; then
    echo -e "${RED}Error: Password ${password} already exists.${NC}"
    return 1
  fi
  
  local expiry_date
  expiry_date=$(date -d "+${days} days" +%s)
  
  echo "${password}:${expiry_date}" >> "$db_file"
  
  jq --arg pass "$password" '.auth.config += [$pass]' /etc/zivpn/config.json > /etc/zivpn/config.json.tmp && \
  mv /etc/zivpn/config.json.tmp /etc/zivpn/config.json
  
  if [ $? -eq 0 ]; then
    restart_zivpn
    local EXPIRE_FORMATTED
    EXPIRE_FORMATTED=$(date -d "@${expiry_date}" "+%B %Y %H:%M")
    
    local ip isp CERT_CN host
    ip=$(cat /etc/zivpn/ip.txt 2>/dev/null || echo "N/A")
    isp=$(cat /etc/zivpn/isp.txt 2>/dev/null || echo "N/A")
    CERT_CN=$(openssl x509 -in /etc/zivpn/zivpn.crt -noout -subject 2>/dev/null | sed -n 's/.*CN = \([^,]*\).*/\1/p' || echo "zivpn")
    
    if [ "$CERT_CN" == "zivpn" ]; then
      host="$ip"
    else
      host="$CERT_CN"
    fi
    
    clear
    echo -e "${LIGHT_GREEN}Access:${NC}"
    echo -e "${CYAN}CREATE AKUN ZIVPN${NC}"
    echo "───────────────────────┐"
    echo "Host   : $host"
    echo "IP     : $ip"
    echo "ISP    : $isp"
    echo "Pass   : $password"
    echo "Expire : $EXPIRE_FORMATTED"
    echo "───────────────────────┘"
    echo -e "${GREEN}Terima kasih telah menggunakan layanan kami${NC}"
    
    local message=$(cat <<EOF
CREATE AKUN ZIVPN
┌────────────────────────┐
│ Host   : $host
│ IP     : $ip
│ ISP    : $isp
│ Pass   : $password
│ Expire : $EXPIRE_FORMATTED
└────────────────────────┘
Terima kasih telah menggunakan layanan kami
EOF
)
    send_telegram_notification "$message"
    return 0
  else
    sed -i "/^${password}:/d" "$db_file"
    echo -e "${RED}Error: Failed to update config.json.${NC}"
    return 1
  fi
}

function create_manual_account() {
  echo "───────── Create New Zivpn Account ────────"
  local password days
  read -p "Enter new password: " password
  
  if [ -z "$password" ]; then
    echo -e "${RED}Error: Password cannot be empty.${NC}"
    return
  fi
  
  read -p "Enter active period (in days): " days
  
  if ! [[ "$days" =~ ^[0-9]+$ ]]; then
    echo -e "${RED}Error: Invalid number of days.${NC}"
    return
  fi
  
  _create_account_logic "$password" "$days"
  read -p "Press Enter untuk kembali ke menu..."
}

function _display_accounts() {
  local db_file="/etc/zivpn/users.db"
  
  if [ ! -f "$db_file" ] || [ ! -s "$db_file" ]; then
    echo -e "${YELLOW}No accounts found.${NC}"
    return
  fi
  
  local current_date
  current_date=$(date +%s)
  
  printf "%-20s │ %s\n" "Password" "Expires in (days)"
  echo "────────────────────────────────────────"
  
  while IFS=: read -r password expiry_date; do
    if [ -n "$password" ]; then
      local remaining_seconds=$((expiry_date - current_date))
      
      if [ "$remaining_seconds" -gt 0 ]; then
        local remaining_days=$((remaining_seconds / 86400))
        printf "%-20s │ %s days\n" "$password" "$remaining_days"
      else
        printf "%-20s │ Expired\n" "$password"
      fi
    fi
  done < "$db_file"
  
  echo "────────────────────────────────────────"
}

function list_accounts() {
  clear
  echo -e "${CYAN}────────── Active Accounts ──────────────${NC}"
  _display_accounts
  echo
  read -p "Press Enter to return to the menu..."
}

function show_menu() {
  if [ -f "/etc/zivpn/.expired" ]; then
    clear
    echo -e "${RED}─────────────────────────────────────────────────────${NC}"
    echo -e "${RED}           LISENSI ANDA TELAH KEDALUWARSA!           ${NC}"
    echo -e "${RED}─────────────────────────────────────────────────────${NC}"
    echo
    echo -e "${BOLD_WHITE}Akses ke layanan ZIVPN di server anda telah dihentikan.${NC}"
    echo -e "${BOLD_WHITE}Semua aktivitas VPN tidak akan berfungsi lagi.${NC}"
    echo
    echo -e "${BOLD_WHITE}Untuk memperpanjang lisensi dan mengaktifkan kembali layanan,${NC}"
    echo -e "${BOLD_WHITE}silahkan hubungi admin https://wa.me/6285647299390${NC}"
    echo
    echo -e "${LIGHT_GREEN}Setelah diperpanjang, layanan akan aktif kembali secara otomatis.${NC}"
    exit 0
  fi
  
  clear
  echo -e "${YELLOW}┌───────────────────────────────────────────────────┐${NC}"
  echo -e "${YELLOW}│${NC}  ${CYAN}ZIVPN Management Menu${YELLOW}                          │${NC}"
  echo -e "${YELLOW}└───────────────────────────────────────────────────┘${NC}"
  echo
  echo -e "${LIGHT_BLUE}1)${NC} ${BOLD_WHITE}Create Account${NC}"
  echo -e "${LIGHT_BLUE}2)${NC} ${BOLD_WHITE}List Accounts${NC}"
  echo -e "${LIGHT_BLUE}3)${NC} ${BOLD_WHITE}Restart Service${NC}"
  echo -e "${LIGHT_BLUE}0)${NC} ${BOLD_WHITE}Exit${NC}"
  echo
  read -p "Enter your choice [0-3]: " choice
  
  case "$choice" in
    1) create_manual_account ;;
    2) list_accounts ;;
    3) systemctl restart zivpn.service --no-block && echo -e "${GREEN}Service restarted!${NC}" ;;
    0) exit 0 ;;
    *) echo -e "${RED}Invalid option. Please try again.${NC}" ;;
  esac
}

function main() {
  if [ $# -gt 0 ]; then
    local command="$1"
    shift
    case "$command" in
      create_account)
        _create_account_logic "$@"
        ;;
      *)
        echo -e "${RED}Error: Unknown command '$command'${NC}"
        exit 1
        ;;
    esac
    exit $?
  fi
  
  if [ ! -f /etc/systemd/system/zivpn.service ]; then
    echo -e "${RED}ZIVPN service not found. Please install it first.${NC}"
    exit 1
  fi
  
  while true; do
    show_menu
  done
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
